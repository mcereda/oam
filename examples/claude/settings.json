{
    "outputStyle": "Explanatory",
    "autoUpdatesChannel": "stable",
    "minimumVersion": "2.1.76",
    "prefersReducedMotion": true,
    "voiceEnabled": true,

    "model": "opusplan",
    "effortLevel": "medium",
    "alwaysThinkingEnabled": true,

    "env": {
        "DISABLE_TELEMETRY": "1"
    },

    "permissions": {
        "defaultMode": "plan",
        "allow": [
            "Bash(npm run lint)",
            "Bash(npm run test *)",
            "Read(~/.zshrc)"
        ],
        "deny": [
            "Bash(curl *)",
            "Read(./.env)",
            "Read(./.env.*)"
        ]
    },
    "sandbox": {
        "enabled": true,
        "autoAllowBashIfSandboxed": true,
        "excludedCommands": [
            "docker"
        ],
        "network": {
            "allowedDomains": [
                "github.com",
                "*.npmjs.org",
                "registry.yarnpkg.com"
            ],
            "allowUnixSockets": [
                "/var/run/docker.sock"
            ],
            "allowLocalBinding": true
        }
    },

    "enabledPlugins": {
        "skill-creator@claude-plugins-official": true,
        "gitlab@claude-plugins-official": true
    },
    "disabledMcpServers": [
        "claude-in-chrome"
    ],
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
                    }
                ]
            }
        ]
    }
}
