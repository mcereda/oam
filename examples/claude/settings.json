{
    "outputStyle": "Explanatory",
    "autoUpdatesChannel": "stable",
    "minimumVersion": "2.1.76",
    "prefersReducedMotion": true,
    "voiceEnabled": true,

    "model": "opusplan",
    "effortLevel": "medium",
    "alwaysThinkingEnabled": true,

    "env": {
        "DISABLE_TELEMETRY": "1"
    },

    "permissions": {
        "defaultMode": "plan",
        "allow": [
            "Bash(npm run lint)",
            "Bash(npm run test *)",
            "Read(~/.zshrc)"
        ],
        "deny": [
            "Bash(curl *)",
            "Read(./.env)",
            "Read(./.env.*)"
        ]
    },
    "sandbox": {
        "enabled": true,
        "autoAllowBashIfSandboxed": true,
        "excludedCommands": [
            "docker",
            "git"
        ],
        "network": {
            "allowedDomains": [
                "github.com",
                "*.npmjs.org",
                "registry.yarnpkg.com"
            ],
            "allowUnixSockets": [
                "/var/run/docker.sock"
            ],
            "allowLocalBinding": true
        }
    },

    "enabledPlugins": {
        "skill-creator@claude-plugins-official": true,
        "gitlab@claude-plugins-official": true
    },
    "disabledMcpServers": [
        "claude-in-chrome"
    ],
    "hooks": {
        "Notification": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
                    },
                    {
                        "type": "command",
                        "if": "Bash(git commit*)",
                        "command": "default=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||') && [[ -n \"$default\" && \"$(git branch --show-current)\" == \"$default\" ]] && echo \"BLOCKED: on '$default', create a feature branch first.\" && exit 2; exit 0"
                    },
                    {
                        "type": "agent",
                        "prompt": "Review the proposed Bash command. Block it if it would: delete files outside the working directory, force-push, run pulumi up/destroy without the non-interactive task wrapper, or modify .env files. Allow everything else.",
                        "timeout": 5
                    }
                ]
            }
        ]
    }
}
