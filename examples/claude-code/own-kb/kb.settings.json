{
    "model": "opus",
    "effortLevel": "high",
    "alwaysThinkingEnabled": true,
    "permissions": {
        "defaultMode": "auto",
        "deny": [],
        "ask": [],
        "allow": [
            "Agent",
            "Bash",
            "Edit(/**)",
            "Read(/**)",
            "Write(/**)"
        ]
    },
    "sandbox": {
        "enabled": false
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "path/to/check-and-review/script.sh"
                    }
                ]
            }
        ]
    }
}
